# =============================================================================
# Dia-Storage - Variabili d'ambiente
# =============================================================================
# Copia questo file in .env.local e personalizza i valori.
# =============================================================================

# Database PostgreSQL
DATABASE_URL="postgres://dia:dia@localhost:5432/dia_storage"

# Percorso base archiviazione (volumi Docker o directory locale)
# STORAGE_BASE_PATH="/data"

# Percorso file di configurazione (default: config.yaml nella root)
# CONFIG_PATH="./config.yaml"

# ---------------------------------------------------------------------------
# Override configurazione via variabili d'ambiente
# Formato: DIA_{SEZIONE}__{CAMPO}
# Il doppio underscore separa sezione e campo.
# ---------------------------------------------------------------------------

# App
# DIA_APP__NAME="Dia-Storage"
# DIA_APP__URL="http://localhost:3000"
# DIA_APP__LOG_LEVEL="debug"

# Auth
# DIA_AUTH__OTP_EXPIRY_MINUTES=10
# DIA_AUTH__SESSION_EXPIRY_DAYS=30

# Email SMTP
# DIA_EMAIL__HOST="smtp.example.com"
# DIA_EMAIL__PORT=587
# DIA_EMAIL__SECURE=false
# DIA_EMAIL__USER=""
# DIA_EMAIL__PASSWORD=""
# DIA_EMAIL__FROM="noreply@example.com"

# WhatsApp (opzionale)
# DIA_WHATSAPP__ENABLED=false
# DIA_WHATSAPP__PHONE_NUMBER_ID=""
# DIA_WHATSAPP__ACCESS_TOKEN=""

# Seed script
# ADMIN_EMAIL="admin@dia-storage.local"
# ADMIN_NAME="Amministratore"
